# ============================================================
# voice2ai — environment template
# Copy to config.env, fill the provider you want to use.
# Legacy VOICE2CC_* names are still loaded as deprecated aliases.
# ============================================================

# Which STT provider to use: siliconflow / openai / groq / azure
VOICE2AI_PROVIDER=siliconflow

# --------- SiliconFlow (default, low-cost Chinese ASR) ---------
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=FunAudioLLM/SenseVoiceSmall

# --------- OpenAI Whisper ---------
OPENAI_API_KEY=
OPENAI_MODEL=whisper-1

# --------- Groq Whisper (fast, free tier) ---------
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3

# --------- Azure Speech ---------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# --------- Behaviour (optional) ---------
VOICE2AI_HOTKEY=f8                              # push-to-talk key
VOICE2AI_CONTINUOUS_TOGGLE_HOTKEY=f9            # continuous-mode toggle
VOICE2AI_LANGUAGE=auto                          # auto / en / zh
VOICE2AI_AUTO_ENTER_AFTER_PASTE=true            # paste then press Enter
